# Copy to .env and fill in real values. The .env file is gitignored.

PORT=5001
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DB_NAME=e-commerce
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRE=30d
SALT_ROUNDS=10

# Seeded admin account (used by create-admin.js)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@1234

# URL of the Vue client (used for Stripe success/cancel redirects)
CLIENT_URL=http://localhost:5173

# Stripe — use TEST keys only: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen --forward-to localhost:5000/api/v1/payments/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxx
